{
  "name": "dailyhot-api",
  "version": "2.0.8",
  "description": "An Api on Today's Hot list",
  "keywords": [
    "API",
    "RSS"
  ],
  "homepage": "https://github.com/imsyy/DailyHotApi#readme",
  "bugs": {
    "url": "https://github.com/imsyy/DailyHotApi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imsyy/DailyHotApi.git"
  },
  "license": "MIT",
  "author": "tnnevol",
  "main": "dist/index.js",
  "declaration": true,
  "declarationMap": true,
  "sourceMap": true,
  "files": [
    "LICENSE",
    "README.md",
    "dist/**/*",
    "!dist/logs/**/*"
  ],
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "dev:local": "dotenv -e .env.local -- tsx watch --no-cache src/index.ts",
    "dev": "dotenv -e .env.development -- tsx watch --no-cache src/index.ts",
    "dev:cache": "dotenv -e .env.development -- tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "build:sender": "pnpm -F @tnnevol/dingtalk-sender run build",
    "start:local": "dotenv -e .env.local -- node dist/index.js",
    "start:sender": "pnpm -F @tnnevol/dingtalk-sender run start",
    "start": "dotenv -e .env.development -- node dist/index.js",
    "build:dts": "pnpm --filter \"@tnnevol/dingtalk-sender\" build",
    "workers:dev": "wrangler dev workers-adapter.ts",
    "workers:deploy": "wrangler deploy workers-adapter.ts",
    "workers:typecheck": "tsc --noEmit --skipLibCheck workers-adapter.ts"
  },
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^1.17.1",
    "@tnnevol/robot-ding": "^5.2.9",
    "axios": "^1.11.0",
    "chalk": "^5.4.1",
    "cheerio": "^1.1.2",
    "dayjs": "^1.11.13",
    "dotenv": "^17.2.1",
    "feed": "^5.1.0",
    "flatted": "^3.3.3",
    "hono": "^4.8.9",
    "https-proxy-agent": "^8.0.0",
    "iconv-lite": "^0.6.3",
    "ioredis": "^5.6.1",
    "md5": "^2.3.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "rss-parser": "^3.13.0",
    "user-agents": "^1.1.614",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@eslint/js": "^9.32.0",
    "@types/md5": "^2.3.5",
    "@types/node": "^22.19.15",
    "@types/user-agents": "^1.0.4",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.32.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "unbuild": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
